{
    "name": "mathisderoy/facturflow-invoices-for-woocommerce",
    "description": "Génère des factures Factur-X conformes à la réforme française 2026 depuis WooCommerce (PDF/A-3 + XML CII embarqué, profil EN 16931).",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Mathis Deroy",
            "email": "mathis.deroy@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "horstoeko/zugferd": "^1.0",
        "tecnickcom/tcpdf": "^6.7"
    },
    "autoload": {
        "classmap": [
            "includes/"
        ]
    },
    "config": {
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "platform": {
            "php": "8.0.0"
        },
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "audit": {
            "ignore": {
                "GHSA-vvj3-c3rp-c85p": "PHPUnit is a dev-only test tool; the 9.x line is EOL and never ships to production (release build uses --no-dev). Advisory irrelevant to end users."
            }
        }
    },
    "extra": {
        "strauss": {
            "target_directory": "vendor-prefixed",
            "namespace_prefix": "Mathis\\FacturX\\Vendor\\",
            "classmap_prefix": "Mathis_FacturX_Vendor_",
            "constant_prefix": "MATHISFX_VENDOR_",
            "delete_vendor_packages": true,
            "include_modified_date": false,
            "include_author": false
        }
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "3.1",
        "phpcompatibility/phpcompatibility-wp": "2.1",
        "phpunit/phpunit": "9.6"
    }
}
